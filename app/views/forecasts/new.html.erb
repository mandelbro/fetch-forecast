<% content_for(:title, "Fetch Forecast") %>

<main class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h1 class="mb-3">Fetch Forecast</h1>
      <p class="text-muted mb-4">
        Enter a US address to get the current weather and 5-day forecast.
      </p>

      <% if flash[:alert] %>
        <div class="alert alert-warning" role="alert">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: forecast_path, method: :get do |f| %>
        <div class="mb-3">
          <%= f.label :address, class: "form-label" %>
          <%= f.text_field :address,
                value: @address,
                placeholder: "e.g. 1 Apple Park Way, Cupertino, CA 95014",
                autofocus: true,
                class: "form-control form-control-lg" %>
        </div>
        <%= f.submit "Get Forecast", class: "btn btn-primary btn-lg w-100" %>
      <% end %>
    </div>
  </div>
</main>
