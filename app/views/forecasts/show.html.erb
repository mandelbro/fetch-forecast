<% content_for(:title, "Forecast for #{@response[:forecast].location_name}") %>
<% forecast = @response[:forecast] %>

<main class="forecast-result">
  <h1><%= forecast.location_name %>, <%= forecast.country_code %></h1>
  <p class="zip-code">ZIP: <%= forecast.zip_code %></p>

  <% if @response[:cached] %>
    <p class="cache-status">
      Cached forecast &mdash; fetched <%= @response[:age_seconds] %> seconds ago
    </p>
  <% end %>

  <section class="current-conditions">
    <h2>Current Conditions</h2>
    <p class="current-temp"><%= number_with_precision(forecast.current_temp, precision: 0) %>&deg;F</p>
    <p>Feels like <%= number_with_precision(forecast.feels_like, precision: 0) %>&deg;F</p>
    <p><%= forecast.conditions %></p>
    <p>High: <%= number_with_precision(forecast.high, precision: 0) %>&deg;F &bull;
       Low: <%= number_with_precision(forecast.low, precision: 0) %>&deg;F</p>
  </section>

  <% if forecast.extended.any? %>
    <section class="extended-forecast">
      <h2>5-Day Forecast</h2>
      <div class="forecast-days">
        <% forecast.extended.each do |day| %>
          <div class="forecast-day">
            <p class="date"><%= day["date"] %></p>
            <p class="conditions"><%= day["conditions"] %></p>
            <p class="temps">
              <span class="high"><%= day["high"] %>&deg;</span> /
              <span class="low"><%= day["low"] %>&deg;</span>
            </p>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <p class="back-link"><%= link_to "Search another address", root_path %></p>
</main>
